--- TESTCASE Create company for employee tests
--- HTTP
## TEST-EXPECT-STATUS: [201]
## TEST-HAS-BODY
# @name CreateCompanyRequest
POST {{ApiBaseUrl}}/api/companies
Content-Type: application/json

{
  "code": "FIRM-EMP-001",
  "name": "Test Firma pre Zamestnancov"
}
--- TEST
await tp.Test("Company should be created.", async () =>
{
    dynamic responseJson = await tp.Responses["CreateCompanyRequest"].GetBodyAsExpandoAsync();
    NotNull(responseJson);
    True(responseJson.id > 0);
    tp.SetVariable("CompanyId", (long)responseJson.id);
});
--- END


--- TESTCASE Create employee
--- HTTP
## TEST-EXPECT-STATUS: [201]
## TEST-HAS-BODY
# @name CreateEmployeeRequest
POST {{ApiBaseUrl}}/api/employees
Content-Type: application/json

{
  "companyId": {{CompanyId}},
  "title": "Ing.",
  "firstName": "Jan",
  "lastName": "Novak",
  "phone": "+421900123456",
  "email": "jan.novak.emp@firma.sk"
}
--- TEST
await tp.Test("Employee should be created with correct values.", async () =>
{
    dynamic responseJson = await tp.Responses["CreateEmployeeRequest"].GetBodyAsExpandoAsync();
    NotNull(responseJson);
    True(responseJson.id > 0);
    Equal("Jan", (string)responseJson.firstName);
    Equal("Novak", (string)responseJson.lastName);
    Equal("jan.novak.emp@firma.sk", (string)responseJson.email);
    tp.SetVariable("EmployeeId", (long)responseJson.id);
});
--- END


--- TESTCASE Get all employees
--- HTTP
## TEST-EXPECT-STATUS: [200]
## TEST-HAS-BODY
# @name GetAllEmployeesRequest
GET {{ApiBaseUrl}}/api/employees
--- TEST
await tp.Test("Employees response should not be empty.", async () =>
{
    var responseText = await tp.Responses["GetAllEmployeesRequest"].Content.ReadAsStringAsync();
    NotNull(responseText);
    True(responseText.Length > 2);
});
--- END


--- TESTCASE Get employee by id
--- HTTP
## TEST-EXPECT-STATUS: [200]
## TEST-HAS-BODY
# @name GetEmployeeByIdRequest
GET {{ApiBaseUrl}}/api/employees/{{EmployeeId}}
--- TEST
await tp.Test("Returned employee should match created employee.", async () =>
{
    dynamic responseJson = await tp.Responses["GetEmployeeByIdRequest"].GetBodyAsExpandoAsync();
    NotNull(responseJson);
    Equal((long)tp.GetVariable<long>("EmployeeId"), (long)responseJson.id);
    Equal("Jan", (string)responseJson.firstName);
    Equal("Novak", (string)responseJson.lastName);
});
--- END


--- TESTCASE Update employee
--- HTTP
## TEST-EXPECT-STATUS: [200]
## TEST-HAS-BODY
# @name UpdateEmployeeRequest
PUT {{ApiBaseUrl}}/api/employees/{{EmployeeId}}
Content-Type: application/json

{
  "title": "Mgr.",
  "firstName": "Janko",
  "lastName": "Novak",
  "phone": "+421900123456",
  "email": "janko.novak.emp@firma.sk"
}
--- TEST
await tp.Test("Employee should be updated.", async () =>
{
    dynamic responseJson = await tp.Responses["UpdateEmployeeRequest"].GetBodyAsExpandoAsync();
    NotNull(responseJson);
    Equal((long)tp.GetVariable<long>("EmployeeId"), (long)responseJson.id);
    Equal("Janko", (string)responseJson.firstName);
    Equal("Mgr.", (string)responseJson.title);
});
--- END


--- TESTCASE Create employee without email should fail
