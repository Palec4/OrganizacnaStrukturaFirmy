--- TESTCASE Create project
--- HTTP
## TEST-EXPECT-STATUS: [201]
## TEST-HAS-BODY
# @name CreateProjectRequest
POST {{ApiBaseUrl}}/api/projects
Content-Type: application/json

{
  "code": "PROJ-TEAPIE-001",
  "name": "Test Projekt TeaPie",
  "divisionId": {{DivisionId}}
}
--- TEST
await tp.Test("Project should be created with correct values.", async () =>
{
    dynamic responseJson = await tp.Responses["CreateProjectRequest"].GetBodyAsExpandoAsync();
    NotNull(responseJson);
    True(responseJson.id > 0);
    Equal("PROJ-TEAPIE-001", (string)responseJson.code);
    Equal("Test Projekt TeaPie", (string)responseJson.name);
    tp.SetVariable("ProjectId", (long)responseJson.id);
});
--- END


--- TESTCASE Get all projects
--- HTTP
## TEST-EXPECT-STATUS: [200]
## TEST-HAS-BODY
# @name GetAllProjectsRequest
GET {{ApiBaseUrl}}/api/projects
--- TEST
await tp.Test("Projects response should not be empty.", async () =>
{
    var responseText = await tp.Responses["GetAllProjectsRequest"].Content.ReadAsStringAsync();
    NotNull(responseText);
    True(responseText.Length > 2);
});
--- END


--- TESTCASE Get project by id
--- HTTP
## TEST-EXPECT-STATUS: [200]
## TEST-HAS-BODY
# @name GetProjectByIdRequest
GET {{ApiBaseUrl}}/api/projects/{{ProjectId}}
--- TEST
await tp.Test("Returned project should match created project.", async () =>
{
    dynamic responseJson = await tp.Responses["GetProjectByIdRequest"].GetBodyAsExpandoAsync();
    NotNull(responseJson);
    Equal((long)tp.GetVariable<long>("ProjectId"), (long)responseJson.id);
    Equal("Test Projekt TeaPie", (string)responseJson.name);
});
--- END


--- TESTCASE Get division projects
--- HTTP
## TEST-EXPECT-STATUS: [200]
## TEST-HAS-BODY
# @name GetDivisionProjectsRequest
GET {{ApiBaseUrl}}/api/divisions/{{DivisionId}}/projects
--- TEST
await tp.Test("Division projects should not be empty.", async () =>
{
    var responseText = await tp.Responses["GetDivisionProjectsRequest"].Content.ReadAsStringAsync();
    NotNull(responseText);
    True(responseText.Length > 2);
});
--- END


--- TESTCASE Update project
--- HTTP
## TEST-EXPECT-STATUS: [200]
## TEST-HAS-BODY
# @name UpdateProjectRequest
PUT {{ApiBaseUrl}}/api/projects/{{ProjectId}}
Content-Type: application/json

{
  "code": "PROJ-TEAPIE-001",
  "name": "Test Projekt Zmeneny",
  "managerId": {{EmployeeId}}
}
--- TEST
await tp.Test("Project should be updated.", async () =>
{
    dynamic responseJson = await tp.Responses["UpdateProjectRequest"].GetBodyAsExpandoAsync();
    NotNull(responseJson);
    Equal((long)tp.GetVariable<long>("ProjectId"), (long)responseJson.id);
    Equal("Test Projekt Zmeneny", (string)responseJson.name);
});
--- END


--- TESTCASE Create project without code should fail
--- HTTP
## TEST-EXPECT-STATUS: [400]
# @name CreateProjectWithoutCodeRequest
POST {{ApiBaseUrl}}/api/projects
Content-Type: application/json

{
  "code": "",
  "name": "Test Projekt",
  "divisionId": {{DivisionId}}
}
--- END


