--- TESTCASE Create company for department tests
--- HTTP
## TEST-EXPECT-STATUS: [201]
## TEST-HAS-BODY
# @name CreateCompanyRequest
POST {{ApiBaseUrl}}/api/companies
Content-Type: application/json

{
  "code": "FIRM-DEP-001",
  "name": "Test Firma pre Oddelenia"
}
--- TEST
await tp.Test("Company should be created.", async () =>
{
    dynamic responseJson = await tp.Responses["CreateCompanyRequest"].GetBodyAsExpandoAsync();
    NotNull(responseJson);
    True(responseJson.id > 0);
    tp.SetVariable("CompanyId", (long)responseJson.id);
});
--- END


