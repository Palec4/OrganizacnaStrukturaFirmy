--- TESTCASE Create department
--- HTTP
## TEST-EXPECT-STATUS: [201]
## TEST-HAS-BODY
# @name CreateDepartmentRequest
POST {{ApiBaseUrl}}/api/departments
Content-Type: application/json

{
  "code": "DEP-TEAPIE-001",
  "name": "Test Oddelenie TeaPie",
  "projectId": {{ProjectId}}
}
--- TEST
await tp.Test("Department should be created with correct values.", async () =>
{
    dynamic responseJson = await tp.Responses["CreateDepartmentRequest"].GetBodyAsExpandoAsync();
    NotNull(responseJson);
    True(responseJson.id > 0);
    Equal("DEP-TEAPIE-001", (string)responseJson.code);
    Equal("Test Oddelenie TeaPie", (string)responseJson.name);
    tp.SetVariable("DepartmentId", (long)responseJson.id);
});
--- END


--- TESTCASE Get all departments
--- HTTP
## TEST-EXPECT-STATUS: [200]
## TEST-HAS-BODY
# @name GetAllDepartmentsRequest
GET {{ApiBaseUrl}}/api/departments
--- TEST
await tp.Test("Departments response should not be empty.", async () =>
{
    var responseText = await tp.Responses["GetAllDepartmentsRequest"].Content.ReadAsStringAsync();
    NotNull(responseText);
    True(responseText.Length > 2);
});
--- END


--- TESTCASE Get department by id
--- HTTP
## TEST-EXPECT-STATUS: [200]
## TEST-HAS-BODY
# @name GetDepartmentByIdRequest
GET {{ApiBaseUrl}}/api/departments/{{DepartmentId}}
--- TEST
await tp.Test("Returned department should match created department.", async () =>
{
    dynamic responseJson = await tp.Responses["GetDepartmentByIdRequest"].GetBodyAsExpandoAsync();
    NotNull(responseJson);
    Equal((long)tp.GetVariable<long>("DepartmentId"), (long)responseJson.id);
    Equal("Test Oddelenie TeaPie", (string)responseJson.name);
});
--- END


--- TESTCASE Get project departments
--- HTTP
## TEST-EXPECT-STATUS: [200]
## TEST-HAS-BODY
# @name GetProjectDepartmentsRequest
GET {{ApiBaseUrl}}/api/projects/{{ProjectId}}/departments
--- TEST
await tp.Test("Project departments should not be empty.", async () =>
{
    var responseText = await tp.Responses["GetProjectDepartmentsRequest"].Content.ReadAsStringAsync();
    NotNull(responseText);
    True(responseText.Length > 2);
});
--- END


--- TESTCASE Update department
--- HTTP
## TEST-EXPECT-STATUS: [200]
## TEST-HAS-BODY
# @name UpdateDepartmentRequest
PUT {{ApiBaseUrl}}/api/departments/{{DepartmentId}}
Content-Type: application/json

{
  "code": "DEP-TEAPIE-001",
  "name": "Test Oddelenie Zmenene",
  "managerId": {{EmployeeId}}
}
--- TEST


await tp.Test("Department should be updated.", async () =>
{
    dynamic responseJson = await tp.Responses["UpdateDepartmentRequest"].GetBodyAsExpandoAsync();
    NotNull(responseJson);
    Equal((long)tp.GetVariable<long>("DepartmentId"), (long)responseJson.id);
    Equal("Test Oddelenie Zmenene", (string)responseJson.name);
});
--- END


--- TESTCASE Create department without code should fail
